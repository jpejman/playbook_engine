# Playbook Engine Environment Variables
# Version: v0.1.2
# Copy this file to .env and fill in your values

# OpenSearch Configuration
OPENSEARCH_HOST=10.0.0.50
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_USE_SSL=false

# OpenSearch Index Names
OPENSEARCH_INDEX=chat_history
OPENSEARCH_INDEX_PLAYBOOK=chat_history
OPENSEARCH_INDEX_CVE=cve
OPENSEARCH_INDEX_VECTOR=spring-ai-document-index
OPENSEARCH_INDEX_QA_RESULTS=playbook_qa_results-000001

# LLM Configuration (for future use)
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-4
LLM_BASE_URL=https://api.openai.com/v1

# Application Settings
LOG_LEVEL=INFO
MAX_RETRY_ATTEMPTS=3
REQUEST_TIMEOUT=30